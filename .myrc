. "$HOME/.cargo/env"

# enable custom bins
export PATH=$PATH:~/bin

# enable poetry in zsh
fpath+=~/.zfunc


PATH=/usr/local/bin:/usr/bin:/usr/sbin:/bin:/sbin
export PATH=/Users/andrey_semetchkov/.pyenv/bin:/Users/andrey_semetchkov/.poetry/bin:$PATH


#########
# PYTHON
#########
eval "$(pyenv init -)"
eval "$(pyenv virtualenv-init -)"

# Set the default venv to be forter's
pyenv global forter-3.8.6

# Disable pip installs outside of virtualenvs
export PIP_REQUIRE_VIRTUALENV=true

# Disable annoying pyenv venv prompt
export PYENV_VIRTUALENV_DISABLE_PROMPT=1

# solves issues with pip
export DYLD_LIBRARY_PATH=/usr/local/Cellar/openssl@1.1/1.1.1i/lib:/usr/local/Cellar/mysql@5.7/5.7.32/lib
export CPPFLAGS='-I/usr/local/Cellar/openssl@1.1/1.1.1i/include'
export LDFLAGS='-L/usr/local/Cellar/openssl@1.1/1.1.1i/lib'
#gradle
export PATH="/usr/local/opt/openjdk/bin:$PATH"
export PATH=$PATH:/usr/local/Cellar/mysql@5.7/5.7.32/bin



#########
# NODEJS
#########
# NVM and NodeJS configurations
export NVM_DIR="$HOME/.nvm"

__lazynvm()
{
    unset -f nvm node npm __lazynvm
    [ -s "/usr/local/opt/nvm/nvm.sh" ] && . "/usr/local/opt/nvm/nvm.sh"
}
nvm  (){ __lazynvm; nvm  $@; }
node (){ __lazynvm; node $@; }
npm  (){ __lazynvm; npm  $@; }

[ -s "/usr/local/opt/nvm/etc/bash_completion" ] && . "/usr/local/opt/nvm/etc/bash_completion"
export PATH="$NVM_DIR/versions/node/v16.15.1/bin:$PATH"


# Doing it here in order for pipx installed packages to have precedence over venv names
export PATH=/Users/andrey_semetchkov/.local/bin:$PATH
export PATH=/usr/local/go/bin:$PATH
export PATH=/Users/andrey_semetchkov/.cargo/bin:$PATH

#########
# ALIASES
#########

## Git
alias gs='git status'
alias ga='git add'
alias gd='git diff'
alias gc='git add . && git commit --all --message'
alias gcr='git checkout master && git pull && git checkout - && git rebase -i master'
alias gl="git log --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --graph"
alias gcm="git checkout master"
alias gpu="git pull"
alias gcmu="gcm && gpu"
alias gss="git stash save --include-untracked"
alias gsp="git stash pop"
alias grc="git rebase --continue"
alias grm="git rebase -i master"
alias gco="git checkout"
alias gcp="git checkout -"
alias gp="git push"
alias gpf="git push -f"
alias gbd="git branch -D"
alias gdm='git diff master'
alias gca='git commit --amend'
alias gitm='git commit --message'

## Forter git stuff
alias ffc='forter feature create -n'
alias fff='forter feature from -a'
alias foci='forter open ci'
alias fopr='forter open pr'
alias fpr='git push && forter feature pr -o'
alias fprr='fpr -r '

## AWS
alias aws='~/.local/bin/aws2/aws-cli/aws'

## dev
alias cdev='cd ~/dev'
alias ll="ls -al"
# ec2grep
alias ec2use='ec2 ls'
alias ec2usw='ec2 --region us-west-2 ls'
alias ec2euw='ec2 --region eu-west-1 ls'
alias ecuse='ec2 ssh -F ~/.ssh/config'
alias ecusw='ec2 --region us-west-2 ssh -F ~/.ssh/config'

#  Usage:
#  Following chef output in a node:
#  follow_chef <node_ip>
#  Following docker logs on a node:
#  follow_docker <node_ip>
#  sudo_ssh <node_ip>

follow_chef () {
   ssh -F /Users/andrey_semetchkov/.ssh/gozer ubuntu@$1 "tail -f -n 10 /var/log/chef-client.firstboot.log | sed '/Firstboot script done/ q'"
}

follow_docker () {
   ssh -F /Users/andrey_semetchkov/.ssh/gozer ubuntu@$1 "journalctl -f -u docker.service"
}

ssh_re_logstash () {
   ssh -F /Users/andrey_semetchkov/.ssh/gozer -t ubuntu@$1 "echo "Switching to root";sudo --preserve-env docker restart logstash;sudo docker ps"
}

auth () {
    AWS_PROFILE=sso aws sso login
    boundary authenticate oidc -addr https://boundary.frdstr.com:9200 -auth-method-id amoidc_7XurEVv7KV
    HTTPS_PROXY=http://localhost:3128 NO_PROXY=boundary.frdstr.com boundary connect -addr https://boundary.frdstr.com:9200 -target-name "aws main us-east-1 SQUID" -target-scope-name "Engineering" -listen-port 3128 -exec forter -- gozer auth
    HTTPS_PROXY=http://localhost:3128 NO_PROXY=boundary.frdstr.com boundary connect -addr https://boundary.frdstr.com:9200 -target-name "aws main us-east-1 SQUID" -target-scope-name "Engineering" -listen-port 3128 -exec forter -- gozer request
}
